# DashScope API (LLM + ASR 共用同一个 Key)
QWEN_API_KEY=sk-xxxxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# LLM 生成参数
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ASR 模型 (需要与 DashScope Recognition SDK 兼容)
ASR_MODEL=paraformer-realtime-v2

# Embedding + RAG（历史会议知识库）
EMBEDDING_MODEL=text-embedding-v3
RAG_TOP_K=3
RAG_MIN_SCORE=0.3

# 飞书 Incoming Webhook（处理完成后自动推送纪要到群）
FEISHU_WEBHOOK_URL=

# 网页访问密码（留空则不启用密码保护）
ACCESS_PASSWORD=

# 知识库独立密码（留空则仅需主密码）
KNOWLEDGE_PASSWORD=

# 应用配置
UPLOAD_DIR=uploads
DATABASE_PATH=data/meetings.db
